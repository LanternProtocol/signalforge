{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lanternprotocol.org/signalforge/sprint-backlog.schema.json",
  "title": "SignalForge Sprint Backlog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_policy", "sprints"],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "selection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_order",
        "max_items_per_repo_per_run",
        "skip_blocked",
        "require_measurable_tests",
        "require_documentation_update",
        "require_default_branch_sync"
      ],
      "properties": {
        "repo_order": {
          "enum": ["round_robin", "priority"]
        },
        "max_items_per_repo_per_run": {
          "type": "integer",
          "minimum": 1
        },
        "skip_blocked": {
          "type": "boolean"
        },
        "require_measurable_tests": {
          "type": "boolean"
        },
        "require_documentation_update": {
          "type": "boolean"
        },
        "require_default_branch_sync": {
          "type": "boolean"
        }
      }
    },
    "sprints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sprint"
      }
    }
  },
  "$defs": {
    "sprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository_full_name",
        "title",
        "priority",
        "status",
        "area",
        "labels",
        "completion_tests",
        "documentation_targets",
        "done_definition"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9-]+$"
        },
        "repository_full_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "issue": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "enum": ["ready", "blocked", "in_progress", "done", "deferred"]
        },
        "area": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "completion_tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/completion_test"
          }
        },
        "documentation_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "done_definition": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "completion_test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": {
          "enum": [
            "automated-test",
            "documentation-review",
            "manual-file-check",
            "manual-github-setting-check",
            "manual-issue-check"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "evidence_required": {
          "type": "string",
          "minLength": 1
        }
      },
      "oneOf": [
        {
          "required": ["command"]
        },
        {
          "required": ["evidence_required"]
        }
      ]
    }
  }
}
